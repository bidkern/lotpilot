# LotPilot local development environment.
# Copy to .env and replace placeholder secrets before running the app.

DATABASE_URL="postgresql://lotpilot:lotpilot@localhost:5432/lotpilot?schema=public"
AUTH_SECRET="replace-with-at-least-16-random-characters"
APP_URL="http://localhost:3000"

# Optional admin/bootstrap values.
ADMIN_EMAIL="owner@example.com"
ADMIN_NAME="Demo Owner"
ADMIN_PASSWORD="replace-with-demo-password"

# Optional demo seed values used by npm run seed:admin.
SEED_DEMO_EMAIL="owner@example.com"
SEED_DEMO_NAME="Demo Owner"
SEED_DEMO_PASSWORD="replace-with-demo-password"
SEED_DEMO_TENANT_NAME="Demo Motors"
SEED_DEMO_WEBSITE_URL="https://www.woosterdodgejeep.com"

# Sync and scraping defaults.
DEFAULT_SYNC_CRON="*/30 * * * *"
SCRAPER_HEADLESS="true"
SCRAPER_DETAIL_CONCURRENCY="5"
PLAYWRIGHT_BROWSER="chromium"
INVENTORY_PERSIST_BATCH_SIZE="20"

# Local artifact storage.
JOBS_EXPORT_DIRECTORY="./runtime-data/exports"
STORAGE_PROVIDER="local"
STORAGE_LOCAL_DIRECTORY="./runtime-data/storage"
IMAGE_CACHE_ENABLED="false"
IMAGE_CACHE_LIMIT_PER_VEHICLE="4"

# Optional S3-compatible storage.
S3_BUCKET_NAME=""
S3_REGION=""
S3_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_FORCE_PATH_STYLE="false"
S3_PUBLIC_BASE_URL=""

# Optional Meta/Facebook Page integration.
META_APP_ID=""
META_APP_SECRET=""
META_GRAPH_API_VERSION="v23.0"
META_REDIRECT_URI="http://localhost:3000/api/meta/callback"
META_VERIFY_TOKEN=""
META_TOKEN_ENCRYPTION_KEY=""
